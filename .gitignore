# MultiScaleDeformableAttention 编译文件
models/ops/build/
models/ops/*.so
models/ops/*.o
models/ops/src/cuda/*.o
models/ops/src/cpu/*.o

# native_rasterizer 编译文件
diff_ras/build/
diff_ras/*.so
diff_ras/*.o
diff_ras/src/*.o

# 通用编译临时文件
*.cu.o
*.cpp.o
*.d

